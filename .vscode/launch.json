{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Run main.py in src",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/pdf-processing-engine/src/main.py",
      "cwd": "${workspaceFolder}/pdf-processing-engine/src",
      "console": "integratedTerminal"
    }
  ]
}
